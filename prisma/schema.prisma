generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String   @default("User")
  phone         String?
  avatar        String?
  role          String   @default("staff") // super_admin, admin, manager, pharmacist, cashier, staff, customer
  branchId      String?
  isActive      Boolean  @default(true)
  lastLogin     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch        Branch?  @relation(fields: [branchId], references: [id])
  attendance    Attendance[]
  activities    ActivityLog[]
  notifications Notification[]
  sales         Sale[]
  expenses      Expense[]
  payrolls      Payroll[]
  shifts        Shift[]
  prescriptions Prescription[] @relation("PrescribedBy")
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// BRANCH & WAREHOUSE
// ============================================

model Branch {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String
  city      String
  phone     String
  email     String?
  managerId String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  inventory Inventory[]
  sales     Sale[]
  expenses  Expense[]
  warehouses Warehouse[]
  purchases Purchase[]
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  branchId  String
  address   String
  capacity  Int      @default(10000)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch    Branch   @relation(fields: [branchId], references: [id])
  inventory Inventory[]
}

// ============================================
// MEDICINE & INVENTORY
// ============================================

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  color     String?
  parentId  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  medicines Medicine[]
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  contactPerson String?
  phone       String
  email       String?
  address     String?
  city        String?
  taxNumber   String?
  paymentTerms String?
  isActive    Boolean  @default(true)
  balance     Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  medicines   Medicine[]
  purchases   Purchase[]
}

model Medicine {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  genericName     String?
  brandName       String?
  categoryId      String
  supplierId      String?
  sku             String   @unique
  barcode         String?
  description     String?
  unit            String   @default("piece") // piece, bottle, box, strip, tube
  packSize        Int      @default(1)
  dosageForm      String?  // tablet, capsule, syrup, injection, cream, etc.
  strength        String?  // 500mg, 250ml, etc.
  prescriptionRequired Boolean @default(false)
  controlled      Boolean  @default(false)
  temperatureZone String?  // room, refrigerated, frozen
  minStock        Int      @default(10)
  maxStock        Int      @default(1000)
  price           Float    // selling price
  costPrice       Float    // purchase price
  discount        Float    @default(0)
  taxRate         Float    @default(0)
  image           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category        Category @relation(fields: [categoryId], references: [id])
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  inventory       Inventory[]
  saleItems       SaleItem[]
  purchaseItems   PurchaseItem[]
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
  reviews         Review[]
  prescriptionItems PrescriptionItem[]
}

model Inventory {
  id            String   @id @default(cuid())
  medicineId    String
  branchId      String?
  warehouseId   String?
  batchNumber   String
  quantity      Int
  reservedQty   Int      @default(0)
  costPrice     Float
  sellingPrice  Float
  manufactureDate DateTime?
  expiryDate    DateTime?
  location      String?  // shelf/rack location
  status        String   @default("in_stock") // in_stock, low_stock, out_of_stock, expired
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  medicine      Medicine  @relation(fields: [medicineId], references: [id])
  branch        Branch?   @relation(fields: [branchId], references: [id])
  warehouse     Warehouse? @relation(fields: [warehouseId], references: [id])
}

// ============================================
// SALES & BILLING
// ============================================

model Sale {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  branchId        String?
  customerId      String?
  cashierId       String
  subtotal        Float
  taxAmount       Float    @default(0)
  discountAmount  Float    @default(0)
  totalAmount     Float
  paidAmount      Float
  changeAmount    Float    @default(0)
  paymentMethod   String   @default("cash") // cash, card, insurance, mobile, mixed
  paymentStatus   String   @default("paid") // paid, partial, pending, refunded
  saleType        String   @default("pos") // pos, online, phone
  prescriptionId  String?  @unique
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch          Branch?     @relation(fields: [branchId], references: [id])
  customer        Customer?   @relation(fields: [customerId], references: [id])
  cashier         User        @relation(fields: [cashierId], references: [id])
  items           SaleItem[]
  prescription    Prescription? @relation(fields: [prescriptionId], references: [id])
  refund          Refund?
}

model SaleItem {
  id            String   @id @default(cuid())
  saleId        String
  medicineId    String
  batchNumber   String?
  quantity      Int
  unitPrice     Float
  costPrice     Float
  discount      Float    @default(0)
  taxRate       Float    @default(0)
  totalPrice    Float
  createdAt     DateTime @default(now())

  sale          Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  medicine      Medicine @relation(fields: [medicineId], references: [id])
}

model Refund {
  id            String   @id @default(cuid())
  saleId        String   @unique
  reason        String
  amount        Float
  status        String   @default("approved") // pending, approved, rejected
  processedBy   String?
  createdAt     DateTime @default(now())

  sale          Sale     @relation(fields: [saleId], references: [id])
}

// ============================================
// PURCHASES
// ============================================

model Purchase {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  supplierId      String
  branchId        String?
  subtotal        Float
  taxAmount       Float    @default(0)
  discountAmount  Float    @default(0)
  totalAmount     Float
  paidAmount      Float    @default(0)
  paymentStatus   String   @default("pending") // paid, partial, pending
  status          String   @default("ordered") // ordered, received, partial, cancelled
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  supplier        Supplier     @relation(fields: [supplierId], references: [id])
  branch          Branch?      @relation(fields: [branchId], references: [id])
  items           PurchaseItem[]
}

model PurchaseItem {
  id            String   @id @default(cuid())
  purchaseId    String
  medicineId    String
  batchNumber   String
  quantity      Int
  receivedQty   Int      @default(0)
  unitCost      Float
  totalPrice    Float
  expiryDate    DateTime?
  manufactureDate DateTime?
  createdAt     DateTime @default(now())

  purchase      Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  medicine      Medicine @relation(fields: [medicineId], references: [id])
}

// ============================================
// CUSTOMERS
// ============================================

model Customer {
  id              String   @id @default(cuid())
  name            String
  email           String?  @unique
  phone           String   @unique
  address         String?
  city            String?
  dateOfBirth     DateTime?
  gender          String?
  bloodGroup      String?
  allergies       String?
  medicalConditions String?
  insuranceProvider String?
  insuranceNumber String?
  loyaltyPoints   Int      @default(0)
  totalSpent      Float    @default(0)
  totalOrders     Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sales           Sale[]
  prescriptions   Prescription[]
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
  orders          Order[]
  reviews         Review[]
}

// ============================================
// PRESCRIPTIONS
// ============================================

model Prescription {
  id            String   @id @default(cuid())
  prescriptionNumber String @unique
  customerId    String
  doctorName    String
  doctorLicense String?
  prescribedBy  String?
  diagnosis     String?
  notes         String?
  status        String   @default("pending") // pending, verified, dispensed, expired
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer      Customer @relation(fields: [customerId], references: [id])
  prescribedByUser User?  @relation("PrescribedBy", fields: [prescribedBy], references: [id])
  items         PrescriptionItem[]
  sale          Sale?
}

model PrescriptionItem {
  id             String   @id @default(cuid())
  prescriptionId String
  medicineId     String
  dosage         String
  frequency      String
  duration       String
  quantity       Int
  instructions   String?
  createdAt      DateTime @default(now())

  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicine       Medicine     @relation(fields: [medicineId], references: [id])
}

// ============================================
// ONLINE ORDERS & CART
// ============================================

model CartItem {
  id          String   @id @default(cuid())
  customerId  String
  medicineId  String
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  medicine    Medicine @relation(fields: [medicineId], references: [id])
}

model WishlistItem {
  id          String   @id @default(cuid())
  customerId  String
  medicineId  String
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  medicine    Medicine @relation(fields: [medicineId], references: [id])
}

model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  customerId      String
  items           String   // JSON array of order items
  subtotal        Float
  taxAmount       Float    @default(0)
  discountAmount  Float    @default(0)
  deliveryFee     Float    @default(0)
  totalAmount     Float
  paymentMethod   String   @default("cash")
  paymentStatus   String   @default("pending")
  status          String   @default("pending") // pending, confirmed, processing, shipped, delivered, cancelled
  shippingAddress String
  city            String
  phone           String
  notes           String?
  trackingNumber  String?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer        Customer @relation(fields: [customerId], references: [id])
}

// ============================================
// REVIEWS
// ============================================

model Review {
  id          String   @id @default(cuid())
  customerId  String
  medicineId  String
  rating      Int      // 1-5
  title       String?
  comment     String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id])
  medicine    Medicine @relation(fields: [medicineId], references: [id])
}

// ============================================
// EMPLOYEES & HR
// ============================================

model Attendance {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  status      String   @default("present") // present, absent, late, half_day, leave
  notes       String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model Shift {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  startTime   DateTime
  endTime     DateTime
  branchId    String?
  status      String   @default("scheduled") // scheduled, in_progress, completed, missed
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model Payroll {
  id              String   @id @default(cuid())
  userId          String
  month           String   // "2025-01"
  basicSalary     Float
  overtimeHours   Float    @default(0)
  overtimeAmount  Float    @default(0)
  bonus           Float    @default(0)
  deductions      Float    @default(0)
  tax             Float    @default(0)
  netSalary       Float
  status          String   @default("pending") // pending, paid, cancelled
  paidAt          DateTime?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  branchId    String?
  category    String   // rent, utilities, supplies, maintenance, salary, other
  amount      Float
  description String?
  receipt     String?
  date        DateTime @default(now())
  recordedBy  String   @default("system")
  createdAt   DateTime @default(now())

  branch      Branch?  @relation(fields: [branchId], references: [id])
  recorder    User?    @relation(fields: [recordedBy], references: [id])
}

// ============================================
// NOTIFICATIONS & ACTIVITY
// ============================================

model Notification {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  message     String
  type        String   @default("info") // info, warning, error, success, alert
  category    String?  // inventory, sales, system, hr, order
  isRead      Boolean  @default(false)
  link        String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entity      String?
  entityId    String?
  details     String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])
}

// ============================================
// SETTINGS
// ============================================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  category  String?  // general, pharmacy, billing, notification, appearance
  updatedAt DateTime @updatedAt
}

// ============================================
// NEWSLETTER
// ============================================

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ============================================
// PROMOTIONS
// ============================================

model Promotion {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("percentage") // percentage, fixed, bogo
  value       Float
  code        String   @unique
  minOrder    Float    @default(0)
  maxDiscount Float?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  usageLimit  Int?
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
